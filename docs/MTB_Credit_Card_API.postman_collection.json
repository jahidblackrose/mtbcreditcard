                  "value": "{{session_id}}"
                }
              ]
            },
            "description": "Extend session TTL\n\nProcedure: 546 (extend_session)"
          },
          "response": []
        },
        {
          "name": "Validate Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/session/:session_id/validate",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "session", ":session_id", "validate"],
              "variable": [
