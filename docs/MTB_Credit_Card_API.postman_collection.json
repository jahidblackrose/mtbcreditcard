              "raw": "{{base_url}}{{api_prefix}}/session/create",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "session", "create"]
            },
            "description": "Create a new application session\n\nProcedure: 544 (create_session)"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.status === 200) {",
                  "    pm.collectionVariables.set(\"session_id\", jsonData.data.session_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/session/:session_id",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "session", ":session_id"],
              "variable": [
                {
                  "key": "session_id",
                  "value": "{{session_id}}"
                }
              ]
            },
            "description": "Get session details by session ID\n\nProcedure: 545 (get_session)"
          },
          "response": []
        },
        {
          "name": "Extend Session",
