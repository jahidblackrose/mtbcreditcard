        {
          "name": "End Session",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/session/:session_id",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "session", ":session_id"],
              "variable": [
                {
                  "key": "session_id",
                  "value": "{{session_id}}"
                }
              ]
            },
            "description": "End/delete a session\n\nProcedure: 547 (end_session)"
          },
          "response": []
        }
