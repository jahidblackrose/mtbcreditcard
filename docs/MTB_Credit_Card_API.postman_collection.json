    {
      "name": "1. Reference Data",
      "item": [
        {
          "name": "Get Card Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/reference/card-products",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "reference", "card-products"]
            },
            "description": "Get all available credit card products\n\nProcedure: 501 (get_card_products)"
          },
          "response": []
        },
        {
          "name": "Get Reference Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/reference/reference/:type",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "reference", "reference", ":type"],
              "variable": [
                {
                  "key": "type",
                  "value": "MARITAL_STATUS",
                  "description": "Reference data type (CARD_NETWORK, CARD_TIER, CARD_CATEGORY, CUSTOMER_SEGMENT, EMPLOYMENT_TYPE, PROFESSION, NID_TYPE, MARITAL_STATUS, GENDER, EDUCATION, ADDRESS_TYPE, BANK, DOCUMENT_TYPE)"
                }
              ]
            },
            "description": "Get reference data by type\n\nProcedure: 502 (get_reference_data)"
          },
          "response": []
        },
        {
          "name": "Check Eligibility",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/reference/check-eligibility?monthly_income=50000",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "reference", "check-eligibility"],
              "query": [
                {
                  "key": "monthly_income",
                  "value": "50000",
                  "description": "Monthly income amount"
                }
              ]
            },
            "description": "Check credit card eligibility based on monthly income\n\nProcedure: 503 (check_eligibility)"
          },
          "response": []
        },
        {
          "name": "Get Banks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/reference/banks",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "reference", "banks"]
            },
            "description": "Get list of banks for bank account selection\n\nProcedure: 504 (get_bank_list)"
          },
          "response": []
        }
      ],
      "description": "Endpoints for retrieving reference data (cards, banks, occupations, etc.)"
    },
    {
      "name": "2. Authentication",
      "item": [
        {
          "name": "Check Existing Applicant",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nid_number\": \"1234567890123\",\n  \"mobile_number\": \"01712345678\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/check-existing",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "auth", "check-existing"]
            },
            "description": "Check if an applicant already exists in the system\n\nProcedure: 511 (check_existing_applicant)"
          },
          "response": []
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile_number\": \"01712345678\",\n  \"session_id\": \"{{session_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/otp/request",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "auth", "otp", "request"]
            },
            "description": "Request OTP for mobile verification\n\nRate Limit: 5 requests per hour per mobile number\n\nProcedure: 512 (request_otp)"
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile_number\": \"01712345678\",\n  \"otp\": \"123456\",\n  \"session_id\": \"{{session_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/otp/verify",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "auth", "otp", "verify"]
            },
            "description": "Verify OTP code\n\nRate Limit: Max 5 attempts before lockout (30 minutes)\n\nProcedure: 513 (verify_otp)"
          },
          "response": []
        },
        {
          "name": "Get OTP Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/otp/status?mobile_number=01712345678&session_id={{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "auth", "otp", "status"],
              "query": [
                {
                  "key": "mobile_number",
                  "value": "01712345678"
                },
                {
                  "key": "session_id",
                  "value": "{{session_id}}"
                }
              ]
            },
            "description": "Get OTP verification status\n\nProcedure: 514 (get_otp_status)"
          },
          "response": []
        },
        {
          "name": "Verify OTP Extended",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile_number\": \"01712345678\",\n  \"otp\": \"123456\",\n  \"session_id\": \"{{session_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/otp/verify-extended",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "auth", "otp", "verify-extended"]
            },
            "description": "Verify OTP with extended response (includes user details)\n\nProcedure: 515 (verify_otp_extended)"
          },
          "response": []
        },
        {
          "name": "Staff Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"staff_id\": \"admin\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/staff/login",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "auth", "staff", "login"]
            },
            "description": "Staff login with username/password (JWT)\n\nToken Expiry:\n- Access Token: 15 minutes\n- Refresh Token: 7 days"
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/staff/refresh",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "auth", "staff", "refresh"]
            },
            "description": "Refresh access token using refresh token"
          },
          "response": []
        }
      ],
      "description": "Endpoints for applicant OTP verification and staff JWT authentication"
    },
    {
      "name": "3. Session Management",
      "item": [
        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "header": [],
